// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// customer categories
enum KategoriPelanggan {
  RT
  UM
  PENGECER
}

// payment methods
enum MetodePembayaran {
  TUNAI
  TRANSFER
}

// customer master data
model Pelanggan {
  nik       String            @id // primary key
  nama      String
  kategori  KategoriPelanggan
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  // relation to transactions
  transaksi Transaksi[]
}

// transaction history
model Transaksi {
  id               String           @id @default(cuid()) // unique id
  nikPelanggan     String
  jumlahTabung     Int
  totalHarga       Int
  metodePembayaran MetodePembayaran
  tanggalTransaksi DateTime         @default(now())

  // relation to customer
  pelanggan        Pelanggan        @relation(fields: [nikPelanggan], references: [nik])
  
  // relation to cashier (user) for performance tracking
  kasirId          String
  kasir            User             @relation(fields: [kasirId], references: [id])
  
  // link to specific work session
  sesiId           String?
  sesi             SesiKerja?       @relation(fields: [sesiId], references: [id])
}

// admin/cashier users
model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String   // will store hashed password
  nama      String
  role      String   @default("KASIR") // kasir or admin
  createdAt DateTime @default(now())

  // relation to transactions (performance count)
  transaksi Transaksi[]
  
  // relation to work sessions (shift logs)
  sesiKerja SesiKerja[]
}

// cashier shift/session tracking
model SesiKerja {
  id           String      @id @default(cuid())
  kasirId      String
  kasir        User        @relation(fields: [kasirId], references: [id])
  waktuMulai   DateTime    @default(now())
  waktuSelesai DateTime?   // null means session is still active/abruptly closed

  transaksi    Transaksi[]
}