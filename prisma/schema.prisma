generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// customer categories
enum KategoriPelanggan {
  RT
  UM
  PENGECER
}

// payment methods
enum MetodePembayaran {
  TUNAI
  TRANSFER
}

// customer master data
model Pelanggan {
  nik       String            @id // primary key
  nama      String
  kategori  KategoriPelanggan
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  // relation to transactions
  transaksi Transaksi[]
}

// transaction history
model Transaksi {
  id                String           @id @default(cuid()) // unique id
  nikPelanggan      String
  jumlahTabung      Int
  totalHarga        Int
  metodePembayaran  MetodePembayaran
  tanggalTransaksi  DateTime         @default(now())

  // relation to customer
  pelanggan         Pelanggan        @relation(fields: [nikPelanggan], references: [nik])
}

// admin/cashier users
model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String   // will store hashed password
  nama      String
  role      String   @default("KASIR") // kasir or admin
  createdAt DateTime @default(now())
}
