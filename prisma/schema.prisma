generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// customer categories table
model KategoriPelanggan {
  idKategori   String      @id @default(cuid())
  namaKategori String
  batasKuota   Int
  periodeKuota String      // e.g., "HARI", "MINGGU"

  // relation to customers
  pelanggan    Pelanggan[]
}

// payment status table
model StatusPembayaran {
  idStatus   String      @id @default(cuid())
  namaStatus String

  // relation to transactions
  transaksi  Transaksi[]
}

// product data
model Produk {
  idProduk   String      @id @default(cuid())
  namaProduk String
  harga      Int

  // relation to transactions
  transaksi  Transaksi[]
}

// customer master data
model Pelanggan {
  idPelanggan String            @id @default(cuid())
  nik         String            @unique
  nama        String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  idKategori  String

  // relation to category
  kategori    KategoriPelanggan @relation(fields: [idKategori], references: [idKategori])

  // relation to transactions
  transaksi   Transaksi[]
}

// transaction history
model Transaksi {
  id               String           @id @default(cuid())
  jumlahTabung     Int
  totalHarga       Int
  tanggalTransaksi DateTime         @default(now())
  idPelanggan      String
  idProduk         String
  idStatus         String

  // relations
  pelanggan        Pelanggan        @relation(fields: [idPelanggan], references: [idPelanggan], onDelete: Cascade)
  produk           Produk           @relation(fields: [idProduk], references: [idProduk], onDelete: Cascade)
  status           StatusPembayaran @relation(fields: [idStatus], references: [idStatus])
}

// admin/cashier users
model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  nama      String
  role      String   @default("KASIR")
  createdAt DateTime @default(now())
}
