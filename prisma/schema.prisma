generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// customer categories model
model KategoriPelanggan {
  idKategori   String      @id @default(cuid()) // primary key
  namaKategori String      @unique
  batasKuota   Int         // quota limit number
  periodeKuota String      // quota period (hari or minggu)

  // relation to customers
  pelanggan    Pelanggan[]
}

// payment status model (used for payment methods to maintain flexibility)
model StatusPembayaran {
  idStatus   String      @id @default(cuid()) // primary key
  namaStatus String      @unique

  // relation to transactions
  transaksi  Transaksi[]
}

// product data
model Produk {
  idProduk   String      @id @default(cuid()) // primary key
  namaProduk String
  harga      Int

  // relation to transactions
  transaksi  Transaksi[]
}

// customer master data
model Pelanggan {
  idPelanggan String            @id @default(cuid()) // primary key
  nik         String            @unique
  nama        String
  idKategori  String

  // relation to customer category
  kategori    KategoriPelanggan @relation(fields: [idKategori], references: [idKategori])

  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  // relation to transactions
  transaksi   Transaksi[]
}

// transaction history
model Transaksi {
  id               String           @id // custom unique id based on date
  idPelanggan      String
  idProduk         String
  jumlahTabung     Int
  totalHarga       Int
  idStatus         String
  tanggalTransaksi DateTime         @default(now())

  // relation to payment status
  status           StatusPembayaran @relation(fields: [idStatus], references: [idStatus])

  // relation to customer
  pelanggan        Pelanggan        @relation(fields: [idPelanggan], references: [idPelanggan], onDelete: Cascade)

  // relation to product
  produk           Produk           @relation(fields: [idProduk], references: [idProduk], onDelete: Cascade)
}

// admin/cashier users
model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String   // will store hashed password
  nama      String
  role      String   @default("KASIR") // kasir or admin
  createdAt DateTime @default(now())
}
