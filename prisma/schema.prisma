generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// customer categories
enum KategoriPelanggan {
  RT
  UM
  PENGECER
}

// payment methods
enum MetodePembayaran {
  TUNAI
  TRANSFER
}

// product data
model Produk {
  idProduk   String      @id @default(cuid()) // primary key
  namaProduk String
  harga      Int

  // relation to transactions
  transaksi  Transaksi[]
}

// customer master data
model Pelanggan {
  idPelanggan String            @id @default(cuid()) // primary key
  nik         String            @unique
  nama        String
  kategori    KategoriPelanggan
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  // relation to transactions
  transaksi   Transaksi[]
}

// transaction history
model Transaksi {
  id               String           @id @default(cuid()) // unique id
  idPelanggan      String
  idProduk         String
  jumlahTabung     Int
  totalHarga       Int
  metodePembayaran MetodePembayaran
  tanggalTransaksi DateTime         @default(now())

  // relation to customer
  pelanggan        Pelanggan        @relation(fields: [idPelanggan], references: [idPelanggan], onDelete: Cascade)

  // relation to product
  produk           Produk           @relation(fields: [idProduk], references: [idProduk], onDelete: Cascade)
}

// admin/cashier users
model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String   // will store hashed password
  nama      String
  role      String   @default("KASIR") // kasir or admin
  createdAt DateTime @default(now())
}
